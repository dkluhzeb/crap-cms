root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{rs,toml}]
indent_size = 4

[*.md]
# Two trailing spaces is a hard line-break in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
