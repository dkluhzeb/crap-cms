{{!--
  Overlay for the stock `templates/fields/number.hbs` that adds a
  `<crap-stars>` rendering branch for fields literally named `rating`.
  Falls through to the upstream default for everything else — re-emit
  the stock number input here so this overlay wins for ALL number
  fields without breaking the non-rating ones.

  Match key: `field_name` is the bare name from the collection
  definition (always `"rating"` no matter how nested), versus `name`
  which is the qualified form-input path (`"rating"`, `"seo__rating"`,
  `"items[0][rating]"`, …). Matching on `field_name` makes the widget
  appear correctly for nested rating fields too. Don't bypass it —
  an overlay with `(eq name "rating")` silently breaks for any nested
  use.

  Trade-off: this still couples the template to a specific *literal*
  field name. For a redistributable plugin shipped to many users
  (where the consumer might name the field anything), an explicit
  hint mechanism would be the right tool; for a single-site
  customization, name-matching is the cleanest.
--}}
{{#> partials/field}}
  {{#if (and (eq field_name "rating") (not has_many))}}
    <crap-stars
      id="field-{{name}}"
      name="{{name}}"
      value="{{value}}"
      max="{{#if has_max}}{{max}}{{else}}5{{/if}}"
      {{#if required}}required{{/if}}
      {{#if readonly}}readonly{{/if}}
      {{#if error}}data-error{{/if}}
    ></crap-stars>
  {{else if has_many}}
    <crap-tags
      data-field-type="number"
      {{#if has_min}}data-min="{{min}}"{{/if}}
      {{#if has_max}}data-max="{{max}}"{{/if}}
      {{#if placeholder}}data-placeholder="{{placeholder}}"{{else}}data-placeholder="{{t "type_and_press_enter"}}"{{/if}}
      {{#if readonly}}data-readonly{{/if}}
      {{#if error}}data-error{{/if}}
    >
      <input
        type="hidden"
        name="{{name}}"
        value="{{value}}"
      />
    </crap-tags>
  {{else}}
    <input
      type="number"
      id="field-{{name}}"
      name="{{name}}"
      value="{{value}}"
      step="{{step}}"
      {{#if placeholder}}placeholder="{{placeholder}}"{{/if}}
      {{#if required}}required{{/if}}
      {{#if readonly}}readonly{{/if}}
      {{#if has_min}}min="{{min}}"{{/if}}
      {{#if has_max}}max="{{max}}"{{/if}}
      {{#if error}}class="form__input--error"{{/if}}
    />
  {{/if}}
{{/partials/field}}
