{{#> partials/field}}
{{#if has_many}}
<crap-tags
  data-field-type="{{field_type}}"
  {{#if min_length}}data-min-length="{{min_length}}"{{/if}}
  {{#if max_length}}data-max-length="{{max_length}}"{{/if}}
  {{#if placeholder}}data-placeholder="{{placeholder}}"{{else}}data-placeholder="{{t "type_and_press_enter"}}"{{/if}}
  {{#if readonly}}data-readonly{{/if}}
  {{#if error}}data-error{{/if}}>
  <input type="hidden" name="{{name}}" value="{{value}}" />
</crap-tags>
{{else}}
<input
  type="text"
  id="field-{{name}}"
  name="{{name}}"
  value="{{value}}"
  {{#if placeholder}}placeholder="{{placeholder}}"{{/if}}
  {{#if required}}required{{/if}}
  {{#if readonly}}readonly{{/if}}
  {{#if min_length}}minlength="{{min_length}}"{{/if}}
  {{#if max_length}}maxlength="{{max_length}}"{{/if}}
  {{#if error}}class="form__input--error"{{/if}}
/>
{{/if}}
{{/partials/field}}
