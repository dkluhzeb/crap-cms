{{#> partials/field}}
  <textarea
    id="field-{{name}}"
    name="{{name}}"
    rows="{{rows}}"
    {{#if placeholder}}placeholder="{{placeholder}}"{{/if}}
    {{#if required}}required{{/if}}
    {{#if readonly}}readonly{{/if}}
    {{#if min_length}}minlength="{{min_length}}"{{/if}}
    {{#if max_length}}maxlength="{{max_length}}"{{/if}}
    class="{{#if error}}form__input--error {{/if}}{{#unless resizable}}form__textarea--no-resize{{/unless}}"
  >
    {{value}}
  </textarea>
{{/partials/field}}
