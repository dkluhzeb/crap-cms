{{#> partials/field}}
  <crap-richtext
    {{#if features}}data-features='{{json features}}'{{/if}}
    data-format="{{richtext_format}}"
    {{#if custom_nodes}}data-nodes='{{json custom_nodes}}'{{/if}}
    {{#unless resizable}}data-no-resize{{/unless}}
  >
    <textarea
      id="field-{{name}}"
      name="{{name}}"
      rows="16"
      data-field-type="richtext"
      hidden
      {{#if placeholder}}placeholder="{{placeholder}}"{{/if}}
      {{#if required}}required{{/if}}
      {{#if readonly}}readonly{{/if}}
      {{#if error}}class="form__input--error"{{/if}}
    >
      {{value}}
    </textarea>
  </crap-richtext>
{{/partials/field}}
