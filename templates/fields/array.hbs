<fieldset class="form__array" data-field-type="array" data-field-name="{{name}}"{{#if label_field}} data-label-field="{{label_field}}"{{/if}}>
  <legend>
    {{label}}
    {{#if required}}<span class="required">*</span>{{/if}}
    <span class="form__array-count" id="array-count-{{template_id}}">{{row_count}}</span>
    <span class="form__array-legend-actions">
      <button type="button" class="form__array-legend-btn" data-action="toggle-all-rows-collapse" title="{{t "collapse_all"}}">
        <span class="material-symbols-outlined" style="font-size:14px">unfold_less</span>
      </button>
      <button type="button" class="form__array-legend-btn" data-action="toggle-all-rows-expand" title="{{t "expand_all"}}">
        <span class="material-symbols-outlined" style="font-size:14px">unfold_more</span>
      </button>
    </span>
  </legend>

  <div class="form__array-rows" id="array-rows-{{template_id}}">
    {{#each rows}}
    <div class="form__array-row{{#if ../init_collapsed}}{{#unless this.has_errors}} form__array-row--collapsed{{/unless}}{{/if}}{{#if this.has_errors}} form__array-row--has-errors{{/if}}" data-row-index="{{this.index}}">
      <div class="form__array-row-header" data-action="toggle-array-row">
        <span class="form__array-row-drag" draggable="true" data-drag data-action="noop" title="{{t "drag_to_reorder"}}">
          <span class="material-symbols-outlined" style="font-size:16px">drag_indicator</span>
        </span>
        <span class="form__array-row-chevron material-symbols-outlined">expand_more</span>
        <span class="form__array-row-title">{{#if this.custom_label}}{{this.custom_label}}{{else}}{{../label}} {{this.index}}{{/if}}</span>
        {{#if this.has_errors}}<span class="form__array-row-error-badge" title="{{t "validation_errors"}}"><span class="material-symbols-outlined" style="font-size:16px">error</span></span>{{/if}}
        <button type="button" class="form__array-row-btn" data-action="move-row-up" title="{{t "move_up"}}">
          <span class="material-symbols-outlined" style="font-size:16px">arrow_upward</span>
        </button>
        <button type="button" class="form__array-row-btn" data-action="move-row-down" title="{{t "move_down"}}">
          <span class="material-symbols-outlined" style="font-size:16px">arrow_downward</span>
        </button>
        <button type="button" class="form__array-row-btn" data-action="duplicate-row" title="{{t "duplicate"}}">
          <span class="material-symbols-outlined" style="font-size:16px">content_copy</span>
        </button>
        <button type="button" class="form__array-row-btn" data-action="remove-array-row" title="{{t "remove"}}">
          <span class="material-symbols-outlined" style="font-size:16px">close</span>
        </button>
      </div>
      <div class="form__array-row-body">
        <div class="form__array-row-fields">
          {{#each this.sub_fields}}
          <div class="form__field">
            {{{render_field this}}}
          </div>
          {{/each}}
        </div>
      </div>
    </div>
    {{/each}}
  </div>

  {{#unless rows}}<div class="form__array-empty"><p>{{t "no_items_yet_generic"}}</p></div>{{/unless}}

  <template id="array-template-{{template_id}}">
    <div class="form__array-row" data-row-index="__INDEX__">
      <div class="form__array-row-header" data-action="toggle-array-row">
        <span class="form__array-row-drag" draggable="true" data-drag data-action="noop" title="{{t "drag_to_reorder"}}">
          <span class="material-symbols-outlined" style="font-size:16px">drag_indicator</span>
        </span>
        <span class="form__array-row-chevron material-symbols-outlined">expand_more</span>
        <span class="form__array-row-title">{{label}} __INDEX__</span>
        <button type="button" class="form__array-row-btn" data-action="move-row-up" title="{{t "move_up"}}">
          <span class="material-symbols-outlined" style="font-size:16px">arrow_upward</span>
        </button>
        <button type="button" class="form__array-row-btn" data-action="move-row-down" title="{{t "move_down"}}">
          <span class="material-symbols-outlined" style="font-size:16px">arrow_downward</span>
        </button>
        <button type="button" class="form__array-row-btn" data-action="duplicate-row" title="{{t "duplicate"}}">
          <span class="material-symbols-outlined" style="font-size:16px">content_copy</span>
        </button>
        <button type="button" class="form__array-row-btn" data-action="remove-array-row" title="{{t "remove"}}">
          <span class="material-symbols-outlined" style="font-size:16px">close</span>
        </button>
      </div>
      <div class="form__array-row-body">
        <div class="form__array-row-fields">
          {{#each sub_fields}}
          <div class="form__field">
            {{{render_field this}}}
          </div>
          {{/each}}
        </div>
      </div>
    </div>
  </template>

  <button type="button" class="button button--ghost button--small"
      data-action="add-array-row" data-template-id="{{template_id}}"
      {{#if max_rows}}data-max-rows="{{max_rows}}"{{/if}}>
    <span class="material-symbols-outlined" style="font-size:16px">add</span>
    Add {{#if add_label}}{{add_label}}{{else}}{{t "row"}}{{/if}}
  </button>

  {{#if error}}<p class="form__error">{{error}}</p>{{/if}}
  {{#if description}}<p class="form__help">{{description}}</p>{{/if}}
</fieldset>
