<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script>
    (function(){var t=localStorage.getItem('crap-theme');if(t)document.documentElement.setAttribute('data-theme',t)})();
  </script>
  <link href="/static/styles.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
  <title>Forgot Password - Crap CMS</title>
  <script>
    (function(){
      function gc(n){var m=document.cookie.match(new RegExp('(?:^|; )'+n+'=([^;]*)'));return m?m[1]:null}
      document.addEventListener('submit',function(e){var f=e.target;if(!f||f.tagName!=='FORM')return;var t=gc('crap_csrf');if(t&&!f.querySelector('input[name="_csrf"]')){var i=document.createElement('input');i.type='hidden';i.name='_csrf';i.value=t;f.appendChild(i)}},true);
    })();
  </script>
</head>

<body class="auth-page">
  <div class="auth-card">
    <div class="auth-card__header">
      <span class="material-symbols-outlined auth-card__icon">lock_reset</span>
      <h1 class="auth-card__title">{{t "forgot_password_title"}}</h1>
    </div>

    {{#if success}}
    <div class="auth-card__success">{{t "forgot_password_success"}}</div>
    <a href="/admin/login" class="button button--primary auth-card__submit">{{t "back_to_login"}}</a>
    {{else}}

    {{#if error}}
    <div class="auth-card__error">{{t error}}</div>
    {{/if}}

    <p class="auth-card__message">{{t "forgot_password_message"}}</p>

    <form class="auth-card__form" method="POST" action="/admin/forgot-password">
      {{#if collections}}
      {{#if show_collection_picker}}
      <div class="form__field">
        <label for="collection">{{t "account_type"}}</label>
        <select name="collection" id="collection">
          {{#each collections}}
          <option value="{{this.slug}}">{{this.display_name}}</option>
          {{/each}}
        </select>
      </div>
      {{else}}
      <input type="hidden" name="collection" value="{{collections.[0].slug}}" />
      {{/if}}
      {{/if}}

      <div class="form__field">
        <label for="email">{{t "email"}}</label>
        <input type="email" name="email" id="email" placeholder="you@example.com" required value="{{email}}" autocomplete="email" />
      </div>

      <button type="submit" class="button button--primary auth-card__submit">{{t "send_reset_link"}}</button>
    </form>

    <p class="auth-card__link"><a href="/admin/login">{{t "back_to_login"}}</a></p>
    {{/if}}
  </div>
</body>
</html>
