<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script>
    (function(){var t=localStorage.getItem('crap-theme');if(t)document.documentElement.setAttribute('data-theme',t)})();
  </script>
  <link rel="icon" type="image/svg+xml" href="/static/favicon.svg" />
  <link href="/static/styles.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
  <title>{{t "login_page_title"}} - Crap CMS</title>
  <script>
    (function(){
      function gc(n){var m=document.cookie.match(new RegExp('(?:^|; )'+n+'=([^;]*)'));return m?m[1]:null}
      document.addEventListener('submit',function(e){var f=e.target;if(!f||f.tagName!=='FORM')return;var t=gc('crap_csrf');if(t&&!f.querySelector('input[name="_csrf"]')){var i=document.createElement('input');i.type='hidden';i.name='_csrf';i.value=t;f.appendChild(i)}},true);
    })();
  </script>
</head>

<body class="auth-page">
  <div class="auth-card">
    <div class="auth-card__header">
      <span class="material-symbols-outlined auth-card__icon">memory</span>
      <h1 class="auth-card__title">Crap CMS</h1>
    </div>

    {{#if success}}
    <div class="auth-card__success">{{t success}}</div>
    {{/if}}

    {{#if error}}
    <div class="auth-card__error">{{t error}}</div>
    {{/if}}

    {{#if disable_local}}
    <p class="auth-card__message">{{t "disable_local_message"}}</p>
    {{else}}
    <form class="auth-card__form" method="POST" action="/admin/login">
      {{#if collections}}
      {{#if show_collection_picker}}
      <div class="form__field">
        <label for="collection">{{t "account_type"}}</label>
        <select name="collection" id="collection">
          {{#each collections}}
          <option value="{{this.slug}}" {{#if this.selected}}selected{{/if}}>{{this.display_name}}</option>
          {{/each}}
        </select>
      </div>
      {{else}}
      <input type="hidden" name="collection" value="{{collections.[0].slug}}" />
      {{/if}}
      {{/if}}

      <div class="form__field">
        <label for="email">{{t "email"}}</label>
        <input type="email" name="email" id="email" placeholder="you@example.com" required value="{{email}}" autocomplete="email" />
      </div>

      <div class="form__field">
        <label for="password">{{t "password"}}</label>
        <input type="password" name="password" id="password" placeholder="{{t "password"}}" required autocomplete="current-password" />
      </div>

      <button type="submit" class="button button--primary auth-card__submit">{{t "login"}}</button>

      {{#if show_forgot_password}}
      <p class="auth-card__link"><a href="/admin/forgot-password">{{t "forgot_password"}}</a></p>
      {{/if}}
    </form>
    {{/if}}
  </div>
</body>
</html>
