<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script>
    (function(){var t=localStorage.getItem('crap-theme');if(t)document.documentElement.setAttribute('data-theme',t)})();
  </script>
  <link href="/static/styles.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
  <title>{{t "reset_password_page_title"}} - Crap CMS</title>
  <script>
    (function(){
      function gc(n){var m=document.cookie.match(new RegExp('(?:^|; )'+n+'=([^;]*)'));return m?m[1]:null}
      document.addEventListener('submit',function(e){var f=e.target;if(!f||f.tagName!=='FORM')return;var t=gc('crap_csrf');if(t&&!f.querySelector('input[name="_csrf"]')){var i=document.createElement('input');i.type='hidden';i.name='_csrf';i.value=t;f.appendChild(i)}},true);
    })();
  </script>
</head>

<body class="auth-page">
  <div class="auth-card">
    <div class="auth-card__header">
      <span class="material-symbols-outlined auth-card__icon">lock_reset</span>
      <h1 class="auth-card__title">{{t "reset_password"}}</h1>
    </div>

    {{#if error}}
    <div class="auth-card__error">{{t error}}</div>
    {{#unless token}}
    <a href="/admin/login" class="button button--primary auth-card__submit">{{t "back_to_login"}}</a>
    {{/unless}}
    {{/if}}

    {{#if token}}
    <form class="auth-card__form" method="POST" action="/admin/reset-password">
      <input type="hidden" name="token" value="{{token}}" />

      <div class="form__field">
        <label for="password">{{t "new_password"}}</label>
        <input type="password" name="password" id="password" placeholder="{{t "new_password"}}" required autocomplete="new-password" minlength="1" />
      </div>

      <div class="form__field">
        <label for="password_confirm">{{t "confirm_password"}}</label>
        <input type="password" name="password_confirm" id="password_confirm" placeholder="{{t "confirm_password"}}" required autocomplete="new-password" minlength="1" />
      </div>

      <button type="submit" class="button button--primary auth-card__submit">{{t "reset_password_button"}}</button>
    </form>
    {{/if}}
  </div>
</body>
</html>
