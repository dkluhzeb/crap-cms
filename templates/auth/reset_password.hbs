<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script>
    (function(){var t=localStorage.getItem('crap-theme');if(t)document.documentElement.setAttribute('data-theme',t)})();
  </script>
  <link href="/static/styles.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
  <title>Reset Password - Crap CMS</title>
</head>

<body class="auth-page">
  <div class="auth-card">
    <div class="auth-card__header">
      <span class="material-symbols-outlined auth-card__icon">lock_reset</span>
      <h1 class="auth-card__title">Reset your password</h1>
    </div>

    {{#if error}}
    <div class="auth-card__error">{{error}}</div>
    {{#unless token}}
    <a href="/admin/login" class="button button--primary auth-card__submit">Back to login</a>
    {{/unless}}
    {{/if}}

    {{#if token}}
    <form class="auth-card__form" method="POST" action="/admin/reset-password">
      <input type="hidden" name="token" value="{{token}}" />

      <div class="form__field">
        <label for="password">New password</label>
        <input type="password" name="password" id="password" placeholder="New password" required autocomplete="new-password" minlength="6" />
      </div>

      <div class="form__field">
        <label for="password_confirm">Confirm password</label>
        <input type="password" name="password_confirm" id="password_confirm" placeholder="Confirm password" required autocomplete="new-password" minlength="6" />
      </div>

      <button type="submit" class="button button--primary auth-card__submit">Reset password</button>
    </form>
    {{/if}}
  </div>
</body>
</html>
