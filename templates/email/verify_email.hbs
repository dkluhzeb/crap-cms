<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
    .button { display: inline-block; padding: 12px 24px; background: #2563eb; color: #fff; text-decoration: none; border-radius: 6px; font-weight: 500; }
    .footer { margin-top: 32px; font-size: 13px; color: #888; }
  </style>
</head>
<body>
  <h2>Verify your email</h2>
  <p>Please verify your email address by clicking the button below:</p>
  <p><a class="button" href="{{verify_url}}">Verify Email</a></p>
  <p>If you didn't create an account, you can safely ignore this email.</p>
  <div class="footer">
    <p>Sent by {{from_name}}</p>
  </div>
</body>
</html>
