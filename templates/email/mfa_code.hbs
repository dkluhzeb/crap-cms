<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
      .code { display: inline-block; padding: 16px 32px; background: #f5f5f5; border: 2px solid #ddd; border-radius: 8px; font-size: 32px; font-weight: 700; letter-spacing: 8px; font-family: monospace; }
      .footer { margin-top: 32px; font-size: 13px; color: #888; }
    </style>
  </head>
  <body>
    <h2>Your verification code</h2>
    <p>Enter this code to complete your sign-in:</p>
    <p>
      <span class="code">{{code}}</span>
    </p>
    <p>This code expires in{{expiry_minutes}}minutes.</p>
    <p>
      If you didn't try to sign in, someone may be trying to access your account. You can safely ignore this email.
    </p>
    <div class="footer">
      <p>Sent by{{from_name}}</p>
    </div>
  </body>
</html>
