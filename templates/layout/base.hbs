  <body>
    <div
      class="layout"
      data-admin-layout
    >
      {{> layout/header}}
      <div
        class="sidebar-backdrop"
        data-action="toggle-sidebar"
      >
      </div>
      {{> layout/sidebar}}
      <main
        id="main"
        class="main"
      >
        {{> @partial-block}}
