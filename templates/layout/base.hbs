<!DOCTYPE html>
<html lang="{{#if _locale}}{{_locale}}{{else}}en{{/if}}">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <script nonce="{{crap.csp_nonce}}">
      (function(){var t=localStorage.getItem('crap-theme');if(t)document.documentElement.setAttribute('data-theme',t)})();
    </script>
    <link
      rel="icon"
      type="image/svg+xml"
      href="/static/favicon.svg"
    />
    <link
      href="/static/styles.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
    />
    <!-- Disable HTMX's runtime `<style>` injection. Indicator rules are shipped
       in styles.css instead, so CSP `style-src` doesn't need `'unsafe-inline'`. -->
    <meta
      name="htmx-config"
      content='{"includeIndicatorStyles":false}'
    />
    <script
      src="https://unpkg.com/htmx.org@1.9.12"
      integrity="sha384-ujb1lZYygJmzgSwoxRggbCHcjc0rB2XoQrxeTUQyRjrOnlCoYta87iKBWq3EsdM2"
      crossorigin="anonymous"
    >
    </script>
    <script nonce="{{crap.csp_nonce}}">
      (function(){
      function gc(n){var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+n+'=([^;]*)'));return m?m[1]:null}
      document.addEventListener('htmx:configRequest',function(e){var t=gc('crap_csrf');if(t)e.detail.headers['X-CSRF-Token']=t});
      document.addEventListener('submit',function(e){var f=e.target;if(!f||f.tagName!=='FORM')return;var t=gc('crap_csrf');if(t&&!f.querySelector('input[name="_csrf"]')){var i=document.createElement('input');i.type='hidden';i.name='_csrf';i.value=t;f.appendChild(i)}},true);
      })();
    </script>
    <script
      src="/static/prosemirror.js"
      defer
    >
    </script>
    <script
      src="/static/codemirror.js"
      defer
    >
    </script>
    <script
      type="module"
      src="/static/components/index.js"
    >
    </script>

