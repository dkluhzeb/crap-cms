{{#if ref_count}}
<div class="card card--warning">
  <div class="card__body">
    <p><strong>{{t "delete_has_references"}}</strong></p>
    <p>{{t "referenced_by_count" count=ref_count}}</p>

    <crap-back-refs slug="{{collection.slug}}" doc-id="{{document_id}}">
      <button type="button" class="button button--ghost button--small">
        {{t "show_details"}}
      </button>
    </crap-back-refs>

    <p class="text--muted">{{t "delete_references_warning"}}</p>
  </div>
</div>
{{/if}}

<div class="card">
  <div class="card__body">
    <p>{{t "confirm_delete" name=collection.singular_name}}</p>
    {{#if title_value}}
    <p><strong>{{title_value}}</strong></p>
    {{else}}
    <p><strong>{{document_id}}</strong></p>
    {{/if}}

    <div class="form__actions">
      {{#if ref_count}}
      <button type="button" class="button button--danger" disabled
        title="{{t "cannot_delete_referenced"}}">
        {{t "delete"}}
      </button>
      {{else}}
      <crap-confirm message="{{t "confirm_delete_permanent" name=collection.singular_name}}">
        <form hx-delete="/admin/collections/{{collection.slug}}/{{document_id}}"
              action="/admin/collections/{{collection.slug}}/{{document_id}}"
              method="post"
              hx-target="body">
          <input type="hidden" name="_method" value="DELETE" />
          <button type="submit" class="button button--danger">{{t "delete"}}</button>
        </form>
      </crap-confirm>
      {{/if}}
      <a class="button button--ghost" href="/admin/collections/{{collection.slug}}"
        hx-get="/admin/collections/{{collection.slug}}" hx-target="body" hx-push-url="true">
        {{t "cancel"}}
      </a>
    </div>
  </div>
</div>
