{{!--
  Page metadata — charset, viewport, branding tags, favicon.

  Override by dropping a replacement at
  <config_dir>/templates/partials/meta-tags.hbs in your config dir.

  Note: this partial is for tags that REPLACE the defaults. To ADD
  tags (Open Graph, robots, PWA manifest, custom analytics) without
  touching the defaults, drop a `.hbs` file into the
  `templates/slots/head_extras/` slot directory instead.

  `theme-color` is the browser-chrome tint on mobile (iOS Safari /
  Android Chrome top bar). Default value matches `--color-primary`
  in `styles/tokens.css`. Override to match your brand.
--}}
<meta charset="utf-8" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0"
/>
<meta
  name="theme-color"
  content="#1677ff"
/>
<link
  rel="icon"
  type="image/svg+xml"
  href="/static/icons/favicon.svg"
/>
