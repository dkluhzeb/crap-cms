{{!-- Shared version history table used by both collections/versions.hbs and globals/versions.hbs.
     Expects: versions (array), restore_url_prefix (string) --}}
<div class="card">
  <table class="table">
    <thead>
      <tr>
        <th>{{t "version"}}</th>
        <th>{{t "status"}}</th>
        <th>{{t "created"}}</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each versions}}
      <tr>
        <td><span class="edit-sidebar__version-number">v{{this.version}}</span></td>
        <td><span class="badge badge--{{this.status}}">{{this.status}}</span></td>
        <td><time datetime="{{this.created_at}}">{{this.created_at}}</time></td>
        <td>
          {{#unless this.latest}}
          <form method="post" action="{{../restore_url_prefix}}/versions/{{this.id}}/restore" class="form--inline">
            <button type="submit" class="button button--ghost button--small">{{t "restore"}}</button>
          </form>
          {{/unless}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
